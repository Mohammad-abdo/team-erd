# ── API (REST) ─────────────────────────────────────────────────────────────
# Leave unset for local dev: requests go to /api and Vite proxies to the backend
# (see vite.config.js → server.proxy).
#
# For production or when calling the API directly (no proxy), set the full base URL
# including /api (no trailing slash):
#
#   VITE_API_BASE_URL=https://coffee.qeemasupport.site/team-mg/api
#
# VITE_API_BASE_URL=

# ── Socket.io (optional overrides) ──────────────────────────────────────────
# If VITE_API_BASE_URL is an absolute URL ending in .../api, the client derives
# socket path as .../team-mg/socket.io automatically. Override only if your server
# uses a different path:
#
# VITE_SOCKET_PATH=/team-mg/socket.io
#
# Force socket origin (legacy / escape hatch):
# VITE_SOCKET_ORIGIN=https://coffee.qeemasupport.site/team-mg
# VITE_API_ORIGIN=http://localhost:4000
